# =============================================================================
# Phalanx Kanban Board — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# =============================================================================

# JWT secret key used for signing access tokens.
# IMPORTANT: Change this to a strong, unique value in production!
JWT_SECRET=change-me-to-a-strong-random-secret

# Database connection URL.
# Default uses SQLite (file-based, suitable for development/demo).
# For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./kanban.db

# JWT token expiry in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
